---
/**
 * SPECTER SITE — Hero Section
 *
 * Full-viewport hero with:
 * - Eyebrow positioning line
 * - Text-decrypt animated title (JS, not React)
 * - Body copy with delayed fade-in
 * - Trust line
 * - Release-state-aware dual CTAs
 * - Scan-line overlay (2px intervals, 3% opacity, drifting)
 * - Phosphor glow on title (4s pulse)
 *
 * JS disabled: title renders immediately, CTAs work as anchor links.
 *
 * @see PRD §FR-01 Hero Section
 * @see PRD §16.1 Text Decrypt Animation
 */

import { RELEASE } from '../content/release';
import { resolveReleaseCTAs } from '../lib/release-resolver';

const resolved = resolveReleaseCTAs(RELEASE);
const { primary, secondary } = resolved;

const HERO_TITLE = 'Generate subtitles without uploading your media.';
---

<div class="hero-container">
  {/* Scan-line overlay */}
  <div class="scan-line-overlay" aria-hidden="true"></div>

  <div class="hero-grid">
    {/* Copy column */}
    <div class="hero-copy">
      <p class="hero-eyebrow type-label">Offline subtitle generation for Android</p>

      <h2 class="hero-title type-display" id="hero-title" data-text={HERO_TITLE} aria-label={HERO_TITLE}>
        <span class="hero-title-ghost" aria-hidden="true">{HERO_TITLE}</span>
        <span class="hero-title-text" aria-hidden="true">{HERO_TITLE}</span>
      </h2>

      <p class="hero-body type-body" id="hero-body">
        Import audio, video, or a ZIP archive. SPECTER generates one subtitle file per media file on your device.
      </p>

      <p class="hero-trust type-label">No account. No cloud upload. No transcription server.</p>

      <div class="hero-cta-group">
        {primary.type === 'scroll_to_download' && (
          <a href="#download" class="btn-primary focus-two-ring" id="hero-cta-primary">
            {primary.label}
          </a>
        )}
        {primary.type === 'external_link' && (
          <a href={primary.url} class="btn-primary focus-two-ring" id="hero-cta-primary" target="_blank" rel="noopener noreferrer">
            {primary.label}
          </a>
        )}

        {secondary.type === 'scroll_to_download' && (
          <a href="#download" class="btn-secondary" id="hero-cta-secondary">
            {secondary.label}
          </a>
        )}
        {secondary.type === 'external_link' && (
          <a href={secondary.url} class="btn-secondary" id="hero-cta-secondary" target="_blank" rel="noopener noreferrer">
            {secondary.label}
          </a>
        )}
      </div>
    </div>

    {/* Radar column — ReleaseRadar island injected from index.astro */}
    <div class="hero-radar-slot" id="hero-radar-slot">
      <slot name="radar" />
    </div>
  </div>
</div>

{/* Signal Lock v2 — three-phase text decrypt animation.
    Phase 1 (noise field): chars appear as random uppercase glyphs, dimming progressively.
    Phase 2 (wave resolve): chars lock left-to-right with phosphor glow flash + scan cursor.
    Phase 3 (signal lock): brightness pulse, ambient glow resumes, body fades in.
    Total ~1.7s. Reduced-motion: skipped. No-JS: SSR text rendered as-is. */}
<script>
  const GLYPHS = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';

  // Signal Lock v2 timing constants (ms)
  const NOISE_PHASE = 300;
  const CHAR_STAGGER = 24;
  const SCRAMBLE_CYCLES = 2;
  const SCRAMBLE_INTERVAL = 35;
  const BG_SCRAMBLE = 50;
  const GLOW_FLASH = 250;
  const LOCK_SETTLE = 300;
  const CURSOR_FADE = 120;

  function randomGlyph(): string {
    return GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
  }

  /** Measure each character's rendered position from the ghost span via Range API.
      Preserves natural kerning and text-wrap line breaks. */
  function measureCharPositions(
    ghostSpan: HTMLElement,
    text: string,
    containerRect: DOMRect,
  ): { left: number; top: number; width: number; height: number }[] {
    const walker = document.createTreeWalker(ghostSpan, NodeFilter.SHOW_TEXT);
    const textNode = walker.nextNode();
    if (!textNode || !textNode.textContent) return [];

    const positions: { left: number; top: number; width: number; height: number }[] = [];
    for (let i = 0; i < text.length; i++) {
      const range = document.createRange();
      range.setStart(textNode, i);
      range.setEnd(textNode, i + 1);
      const rect = range.getBoundingClientRect();
      positions.push({
        left: rect.left - containerRect.left,
        top: rect.top - containerRect.top,
        width: rect.width,
        height: rect.height,
      });
      range.detach();
    }
    return positions;
  }

  function resolveChar(span: HTMLSpanElement, finalChar: string): void {
    let cycles = 0;
    span.style.opacity = '0.6';

    const interval = setInterval(() => {
      if (cycles >= SCRAMBLE_CYCLES) {
        clearInterval(interval);
        span.textContent = finalChar;
        span.style.opacity = '1';
        span.dataset.resolved = 'true';
        span.classList.add('decrypt-char-locked');
        setTimeout(() => span.classList.remove('decrypt-char-locked'), GLOW_FLASH);
        return;
      }
      span.textContent = randomGlyph();
      cycles++;
    }, SCRAMBLE_INTERVAL);
  }

  function runSignalLock(): void {
    const el = document.getElementById('hero-title');
    if (!el) return;

    const targetText = el.getAttribute('data-text');
    if (!targetText) return;

    const ghostSpan = el.querySelector('.hero-title-ghost') as HTMLSpanElement | null;
    const textSpan = el.querySelector('.hero-title-text') as HTMLSpanElement | null;
    if (!ghostSpan || !textSpan) return;

    // Measure character positions from ghost's natural text rendering
    const containerRect = el.getBoundingClientRect();
    const charPositions = measureCharPositions(ghostSpan, targetText, containerRect);
    if (charPositions.length !== targetText.length) return;

    // Suppress ambient glow and mark animation active
    el.setAttribute('data-animating', '');

    // Phase 1: Build noise field — absolutely positioned character cells
    const chars = targetText.split('');
    textSpan.textContent = '';
    const spans: HTMLSpanElement[] = [];

    chars.forEach((char, i) => {
      const span = document.createElement('span');
      span.className = 'decrypt-char';

      const pos = charPositions[i];
      span.style.left = `${pos.left}px`;
      span.style.top = `${pos.top}px`;
      span.style.width = `${pos.width}px`;
      span.style.height = `${pos.height}px`;

      if (char === ' ') {
        span.textContent = '\u00A0';
        span.dataset.resolved = 'true';
        span.style.opacity = '0';
      } else {
        span.textContent = randomGlyph();
        span.dataset.resolved = 'false';
        span.style.opacity = '0.35';
      }

      textSpan.appendChild(span);
      spans.push(span);
    });

    // Scan cursor — thin vertical beam tracking the resolve wave
    const cursor = document.createElement('div');
    cursor.className = 'signal-cursor';
    cursor.style.opacity = '0';
    textSpan.appendChild(cursor);

    // Collect non-space character indices for wave ordering
    const nonSpaceIndices: number[] = [];
    chars.forEach((c, i) => {
      if (c !== ' ') nonSpaceIndices.push(i);
    });

    // Background scramble: unresolved characters cycle randomly
    const bgScramble = setInterval(() => {
      for (const span of spans) {
        if (span.dataset.resolved !== 'true') {
          span.textContent = randomGlyph();
        }
      }
    }, BG_SCRAMBLE);

    // Progressive dim — unresolved chars fade during noise phase
    const dimInterval = setInterval(() => {
      for (const span of spans) {
        if (span.dataset.resolved !== 'true') {
          const current = parseFloat(span.style.opacity) || 0.35;
          if (current > 0.18) {
            span.style.opacity = String(Math.max(0.18, current - 0.015));
          }
        }
      }
    }, 40);

    // Phase 2: Wave resolve — characters lock left-to-right
    setTimeout(() => {
      clearInterval(dimInterval);

      // Activate scan cursor
      cursor.style.opacity = '0.85';

      nonSpaceIndices.forEach((charIndex, order) => {
        setTimeout(() => {
          // Track cursor to current character
          const pos = charPositions[charIndex];
          cursor.style.left = `${pos.left}px`;
          cursor.style.top = `${pos.top}px`;
          cursor.style.height = `${pos.height}px`;

          resolveChar(spans[charIndex], chars[charIndex]);
        }, order * CHAR_STAGGER);
      });

      // Phase 3: Signal lock — after all characters resolved
      const waveComplete =
        nonSpaceIndices.length * CHAR_STAGGER +
        SCRAMBLE_CYCLES * SCRAMBLE_INTERVAL +
        80;

      setTimeout(() => {
        clearInterval(bgScramble);

        // Fade scan cursor
        cursor.style.transition = `opacity ${CURSOR_FADE}ms var(--ease-standard)`;
        cursor.style.opacity = '0';

        setTimeout(() => {
          // Restore plain text for proper font shaping/kerning
          textSpan.textContent = targetText;

          // Resume ambient glow
          el.removeAttribute('data-animating');

          // Brightness + glow flash via CSS transition
          el.classList.add('signal-locked');
          setTimeout(() => el.classList.remove('signal-locked'), LOCK_SETTLE);

          // Fade in body text
          const body = document.getElementById('hero-body');
          if (body) body.classList.add('hero-body-visible');
        }, CURSOR_FADE);
      }, waveComplete);
    }, NOISE_PHASE);
  }

  // Respect reduced motion
  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  if (prefersReducedMotion) {
    const body = document.getElementById('hero-body');
    if (body) body.classList.add('hero-body-visible');
  } else {
    // Wait for fonts to load before measuring character positions
    const start = () => requestAnimationFrame(runSignalLock);
    if (document.fonts) {
      document.fonts.ready.then(start);
    } else {
      start();
    }
  }
</script>

<style>
  .hero-container {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: calc(var(--nav-height-desktop) + var(--space-6));
    padding-bottom: var(--space-8);
    padding-left: var(--margin-desktop);
    padding-right: var(--margin-desktop);
    overflow: hidden;
  }

  /* ─── Scan-line overlay ─── */
  .scan-line-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: repeating-linear-gradient(
      to bottom,
      var(--overlay-scanline) 0px,
      var(--overlay-scanline) 1px,
      transparent 1px,
      transparent 2px
    );
    animation: scan-line-drift var(--duration-drift) linear infinite;
  }

  /* ─── Grid ─── */
  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 6fr 1fr 5fr;
    align-items: center;
    gap: 0;
    width: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* ─── Copy column ─── */
  .hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-eyebrow {
    color: var(--text-muted);
    max-width: none;
  }

  .hero-title {
    position: relative;
    color: var(--text-primary);
    animation: phosphor-glow-ambient 4s infinite;
    max-width: 14ch;
    line-height: 0.98;
    letter-spacing: -0.018em;
    transition: filter 300ms var(--ease-enter), text-shadow 300ms var(--ease-enter);
  }

  /* Ghost: invisible layout anchor. Claims the final text height
     so elements below never shift during the decrypt animation. */
  .hero-title-ghost {
    visibility: hidden;
  }

  /* Animation layer: absolutely positioned over ghost,
     free to reflow without affecting document flow. */
  .hero-title-text {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
  }

  /* During decrypt: suppress ambient glow, clip any overflow
     from random character width variance. */
  .hero-title[data-animating] {
    animation: none;
    overflow: hidden;
  }

  /* Each character is absolutely positioned by JS at its measured location.
     Position never changes — only the glyph content cycles during scramble. */
  .hero-title :global(.decrypt-char) {
    position: absolute;
    display: block;
    text-align: center;
    overflow: hidden;
  }

  /* Per-character phosphor glow flash on resolve */
  .hero-title :global(.decrypt-char-locked) {
    animation: decrypt-char-lock 250ms var(--ease-out-expo) both;
  }

  /* Signal lock: brightness + glow flash after all characters resolve */
  .hero-title.signal-locked {
    filter: brightness(1.3);
    text-shadow: 0 0 var(--signal-lock-glow-radius) var(--signal-lock-glow);
  }

  /* Scan cursor — vertical beam tracking the resolve wave */
  .hero-title :global(.signal-cursor) {
    position: absolute;
    width: var(--signal-cursor-width);
    background-color: var(--signal-cursor-color);
    box-shadow: 0 0 8px 2px var(--signal-cursor-color);
    pointer-events: none;
    z-index: 2;
    border-radius: 1px;
  }

  .hero-body {
    color: var(--text-secondary);
    opacity: 0;
    transition: opacity 400ms var(--ease-enter);
  }

  .hero-body.hero-body-visible,
  :global([data-reduced-motion]) .hero-body {
    opacity: 1;
  }

  /* JS-disabled fallback: body is visible immediately */
  @media (scripting: none) {
    .hero-body {
      opacity: 1;
    }
  }

  .hero-trust {
    color: var(--text-accent);
    max-width: none;
  }

  /* ─── CTA Group ─── */
  .hero-cta-group {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding-top: var(--space-1);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-primary-height);
    min-width: var(--btn-primary-min-width);
    padding-left: var(--btn-primary-padding-x);
    padding-right: var(--btn-primary-padding-x);
    background-color: var(--btn-primary-bg);
    color: var(--btn-primary-fg);
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--type-size-label);
    line-height: var(--line-height-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: var(--radius-soft);
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 0 oklch(0.78 0.14 280 / 0.35),
      0 1px 3px 0 oklch(0 0 0 / 0.25);
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard);
  }

  .btn-primary:hover {
    background-color: var(--btn-primary-bg-hover);
    box-shadow:
      inset 0 1px 0 0 oklch(0.88 0.14 280 / 0.35),
      0 2px 8px 0 var(--color-spectra-700);
  }

  .btn-primary:active {
    background-color: var(--btn-primary-bg-pressed);
    box-shadow: inset 0 1px 3px 0 oklch(0 0 0 / 0.2);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--btn-secondary-height);
    padding-left: var(--btn-primary-padding-x);
    padding-right: var(--btn-primary-padding-x);
    background-color: var(--btn-secondary-bg);
    color: var(--btn-secondary-fg);
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--type-size-label);
    line-height: var(--line-height-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--btn-secondary-border);
    border-radius: var(--btn-secondary-radius);
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }

  .btn-secondary:hover {
    background-color: var(--btn-secondary-bg-hover);
    border-color: var(--btn-secondary-border-hover);
  }

  .btn-secondary:active {
    background-color: var(--btn-secondary-bg-pressed);
  }

  /* ─── Radar slot ─── */
  .hero-radar-slot {
    grid-column: 3;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* ─── Tablet ─── */
  @media (max-width: 1023px) {
    .hero-container {
      padding-left: var(--margin-tablet);
      padding-right: var(--margin-tablet);
    }

    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }

    .hero-radar-slot {
      grid-column: 2;
    }
  }

  /* ─── Mobile ─── */
  @media (max-width: 767px) {
    .hero-container {
      padding-top: calc(var(--nav-height-mobile) + var(--space-4));
      padding-left: var(--margin-mobile);
      padding-right: var(--margin-mobile);
      min-height: auto;
      padding-bottom: var(--space-6);
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
      text-align: center;
    }

    .hero-copy {
      align-items: center;
      order: 0;
    }

    .hero-title {
      max-width: none;
    }

    .hero-body {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-cta-group {
      justify-content: center;
    }

    .hero-radar-slot {
      grid-column: 1;
      order: 1;
    }
  }

  /* ─── Reduced motion: no scan-line drift, no glow, no cursor ─── */
  @media (prefers-reduced-motion: reduce) {
    .scan-line-overlay {
      animation: none;
    }

    .hero-title {
      animation: none;
    }

    .hero-body {
      opacity: 1;
      transition: none;
    }

    .hero-title :global(.signal-cursor) {
      display: none;
    }
  }
</style>
